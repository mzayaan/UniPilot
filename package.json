{
  "name": "unipilot",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "build:android": "eas build --platform android",
    "build:ios": "eas build --platform ios",
    "submit:android": "eas submit --platform android",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "node scripts/jest.js --maxWorkers=2 --forceExit",
    "test:watch": "node scripts/jest.js --watch --maxWorkers=2",
    "test:coverage": "node scripts/jest.js --coverage --maxWorkers=2 --forceExit"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.0.0",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@supabase/supabase-js": "^2.45.0",
    "expo": "~51.0.0",
    "expo-auth-session": "~5.5.2",
    "expo-constants": "~16.0.0",
    "expo-document-picker": "~12.0.2",
    "expo-font": "~12.0.0",
    "expo-linking": "~6.3.0",
    "expo-notifications": "~0.28.0",
    "expo-router": "~3.5.0",
    "expo-secure-store": "~13.0.0",
    "expo-splash-screen": "~0.27.0",
    "expo-status-bar": "~1.12.0",
    "expo-web-browser": "~13.0.3",
    "react": "18.2.0",
    "react-native": "0.74.5",
    "react-native-gesture-handler": "~2.16.0",
    "react-native-purchases": "^10.4.0",
    "react-native-reanimated": "~3.10.0",
    "react-native-safe-area-context": "4.10.5",
    "react-native-screens": "3.31.1",
    "react-native-url-polyfill": "^2.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.4.3",
    "@types/jest": "^29.5.12",
    "@types/react": "~18.2.0",
    "babel-jest": "^29.7.0",
    "babel-plugin-module-resolver": "^5.0.3",
    "jest": "^29.7.0",
    "jest-expo": "~51.0.0",
    "react-test-renderer": "18.2.0",
    "typescript": "~5.3.0"
  },
  "jest": {
    "projects": [
      {
        "displayName": "react-native",
        "preset": "jest-expo",
        "testMatch": [
          "<rootDir>/__tests__/components/**/*.test.{ts,tsx}",
          "<rootDir>/__tests__/unit/**/*.test.{ts,tsx}"
        ],
        "setupFilesAfterEnv": [
          "<rootDir>/jest.setup.js"
        ],
        "transformIgnorePatterns": [
          "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|react-native-purchases)"
        ],
        "moduleNameMapper": {
          "^@/(.*)$": "<rootDir>/src/$1"
        }
      },
      {
        "displayName": "hooks",
        "testEnvironment": "node",
        "testMatch": [
          "<rootDir>/__tests__/hooks/**/*.test.{ts,tsx}"
        ],
        "transform": {
          "^.+\\.(ts|tsx|js|jsx)$": [
            "babel-jest",
            {
              "configFile": false,
              "presets": [
                [
                  "@babel/preset-env",
                  {
                    "targets": {
                      "node": "current"
                    }
                  }
                ],
                [
                  "@babel/preset-react",
                  {
                    "runtime": "automatic"
                  }
                ],
                "@babel/preset-typescript"
              ]
            }
          ]
        },
        "moduleNameMapper": {
          "^@/(.*)$": "<rootDir>/src/$1"
        }
      }
    ],
    "collectCoverageFrom": [
      "src/**/*.{ts,tsx}",
      "app/**/*.{ts,tsx}",
      "!**/*.d.ts"
    ]
  }
}
